# Production API endpoint — MUST be your live backend, NOT localhost.
# Replace with your EC2 backend URL. Examples:
#   https://api.dxempire.in/api/v1      (if you set up an api subdomain)
#   http://<EC2_PUBLIC_IP>/api/v1       (quick test, no HTTPS)
VITE_API_URL=https://api.dxempire.in/api/v1

# Served from the domain root, so base path is "/"
VITE_BASE_URL=/
