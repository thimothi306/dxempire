APP_NAME=DXEMPIRE
APP_ENV=production
APP_KEY=                           # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://api.dxempire.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dxempire
DB_USERNAME=dxempire_prod
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@dxempire.com
MAIL_FROM_NAME=DXEMPIRE

# Storage (use S3 in production for invoices, receipts, payslips)
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=dxempire-files
AWS_USE_PATH_STYLE_ENDPOINT=false

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=https://app.dxempire.com,https://admin.dxempire.com

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# SMS
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=

# Logistics
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=Primary
DELHIVERY_TOKEN=
DELHIVERY_SELLER_NAME=DXEMPIRE
DTDC_API_KEY=
DTDC_CUSTOMER_ID=
DTDC_PICKUP_NAME=DXEMPIRE
DTDC_PICKUP_ADDRESS=
DTDC_PICKUP_PINCODE=

# WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886
INTERAKT_API_KEY=

# Push notifications (Expo) — optional but recommended in production
EXPO_ACCESS_TOKEN=

# Monitoring
SENTRY_LARAVEL_DSN=
